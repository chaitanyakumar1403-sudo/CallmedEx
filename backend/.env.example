# ─── Supabase Database & Auth ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ─── Auth & Security ───────────────────────────────────────────────────────
JWT_SECRET=callmedex-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Server Configuration ─────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# ─── AI Services (Gemini Vision for License & Document OCR) ───────────────
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-optional

# ─── Geolocation & Maps (Geoapify — replaces Google Maps) ─────────────────
GEOAPIFY_API_KEY=your-geoapify-api-key-here

# ─── Payment Gateway (Razorpay) ───────────────────────────────────────────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ─── WhatsApp Notifications & Telephony ────────────────────────────────────
WHATSAPP_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_ID=your-whatsapp-phone-number-id

# ─── ABDM (Ayushman Bharat Digital Mission) Integration ───────────────────
ABDM_CLIENT_ID=your-abdm-client-id
ABDM_CLIENT_SECRET=your-abdm-client-secret
ABDM_SANDBOX_URL=https://sandbox.abdm.gov.in

# ─── Email Notification System (Resend API / SMTP / Console Mock) ──────────
# Simply provide RESEND_API_KEY for instant live email sending without SMTP setup!
# If both Resend & SMTP are blank, emails will be logged to backend console (Mock Mode).
RESEND_API_KEY=re_your_resend_api_key_here

# Optional: SMTP fallback (Gmail / SendGrid / AWS SES)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=onboarding@resend.dev

# ─── AI Verification & Registry APIs ──────────────────────────────────────
USE_MOCK_GOV_API=true
NMC_API_URL=https://www.nmc.org.in/api/v1
NURSING_COUNCIL_API_URL=https://indiannursingcouncil.org/api/v1

